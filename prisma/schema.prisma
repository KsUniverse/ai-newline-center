generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  status    OrganizationStatus @default(ACTIVE)
  parentId  String?
  parent    Organization?    @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[]   @relation("OrgTree")
  users     User[]
  douyinAccounts DouyinAccount[]
  douyinLoginSessions DouyinLoginSession[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  account        String       @unique
  passwordHash   String
  name           String
  role           UserRole     @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  douyinAccounts DouyinAccount[]
  douyinLoginSessions DouyinLoginSession[]
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

enum OrganizationType {
  GROUP
  BRANCH
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DouyinAccountType {
  MY_ACCOUNT
  BENCHMARK_ACCOUNT
}

enum DouyinAccountLoginStatus {
  NOT_LOGGED_IN
  PENDING
  LOGGED_IN
  EXPIRED
  FAILED
}

enum DouyinLoginSessionPurpose {
  CREATE_ACCOUNT
  RELOGIN
}

enum DouyinLoginSessionStatus {
  CREATED
  QRCODE_READY
  SCANNED
  CONFIRMED
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

model DouyinAccount {
  id             String            @id @default(cuid())
  profileUrl     String            @unique
  secUserId      String?           @unique
  nickname       String
  avatar         String
  bio            String?
  signature      String?
  followersCount Int               @default(0)
  followingCount Int               @default(0)
  likesCount     Int               @default(0)
  videosCount    Int               @default(0)
  douyinNumber   String?
  ipLocation     String?
  age            Int?
  province       String?
  city           String?
  verificationLabel   String?
  verificationIconUrl String?
  verificationType    Int?
  type           DouyinAccountType @default(MY_ACCOUNT)
  loginStatus    DouyinAccountLoginStatus @default(NOT_LOGGED_IN)
  loginStatePath String?
  loginStateUpdatedAt DateTime?
  loginStateCheckedAt DateTime?
  loginStateExpiresAt DateTime?
  loginErrorMessage String?
  favoriteCookieHeader String?
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  videos         DouyinVideo[]
  loginSessions  DouyinLoginSession[]
  lastSyncedAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  @@index([userId])
  @@index([organizationId])
  @@map("douyin_accounts")
}

model DouyinLoginSession {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation(fields: [userId], references: [id])
  organizationId     String
  organization       Organization             @relation(fields: [organizationId], references: [id])
  accountId          String?
  account            DouyinAccount?           @relation(fields: [accountId], references: [id])
  purpose            DouyinLoginSessionPurpose
  status             DouyinLoginSessionStatus @default(CREATED)
  qrcodeDataUrl      String?
  tempStatePath      String?
  resolvedSecUserId  String?
  errorCode          String?
  errorMessage       String?
  expiresAt          DateTime?
  startedAt          DateTime                 @default(now())
  finishedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([accountId])
  @@index([organizationId, status])
  @@map("douyin_login_sessions")
}

model DouyinVideo {
  id           String        @id @default(cuid())
  videoId      String        @unique
  accountId    String
  account      DouyinAccount @relation(fields: [accountId], references: [id])
  title        String
  coverUrl     String?
  coverSourceUrl String?
  coverStoragePath String?
  videoUrl     String?
  videoSourceUrl String?
  videoStoragePath String?
  publishedAt  DateTime?
  playCount    Int           @default(0)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  collectCount Int           @default(0)
  admireCount  Int           @default(0)
  recommendCount Int         @default(0)
  tags         String[]      @default([])
  snapshots    VideoSnapshot[]
  transcription Transcription?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([accountId])
  @@map("douyin_videos")
}

model VideoSnapshot {
  id            String      @id @default(cuid())
  videoId       String
  video         DouyinVideo @relation(fields: [videoId], references: [id])
  timestamp     DateTime    @default(now())
  playsCount    Int
  likesCount    Int
  commentsCount Int
  sharesCount   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([videoId])
  @@index([videoId, timestamp])
  @@map("video_snapshots")
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transcription {
  id           String              @id @default(cuid())
  videoId      String              @unique
  video        DouyinVideo         @relation(fields: [videoId], references: [id])
  status       TranscriptionStatus @default(PENDING)
  aiModel      String
  originalText String?
  editedText   String?
  errorMessage String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("transcriptions")
}
