generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  status    OrganizationStatus @default(ACTIVE)
  parentId  String?
  parent    Organization?    @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[]   @relation("OrgTree")
  users     User[]
  douyinAccounts DouyinAccount[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  account        String       @unique
  passwordHash   String
  name           String
  role           UserRole     @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  douyinAccounts DouyinAccount[]
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

enum OrganizationType {
  GROUP
  BRANCH
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DouyinAccountType {
  MY_ACCOUNT
  BENCHMARK_ACCOUNT
}

model DouyinAccount {
  id             String            @id @default(cuid())
  profileUrl     String            @unique
  nickname       String
  avatar         String
  bio            String?
  followersCount Int               @default(0)
  videosCount    Int               @default(0)
  type           DouyinAccountType @default(MY_ACCOUNT)
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  videos         DouyinVideo[]
  lastSyncedAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  @@index([userId])
  @@index([organizationId])
  @@map("douyin_accounts")
}

model DouyinVideo {
  id           String        @id @default(cuid())
  videoId      String        @unique
  accountId    String
  account      DouyinAccount @relation(fields: [accountId], references: [id])
  title        String
  coverUrl     String?
  videoUrl     String?
  publishedAt  DateTime?
  playCount    Int           @default(0)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([accountId])
  @@map("douyin_videos")
}
