generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  status    OrganizationStatus @default(ACTIVE)
  parentId  String?
  parent    Organization?    @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[]   @relation("OrgTree")
  users     User[]
  douyinAccounts DouyinAccount[]
  benchmarkAccounts BenchmarkAccount[]
  benchmarkAccountMembers BenchmarkAccountMember[]
  benchmarkVideos BenchmarkVideo[]
  douyinLoginSessions DouyinLoginSession[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  account        String       @unique
  passwordHash   String
  name           String
  role           UserRole     @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  douyinAccounts DouyinAccount[]
  createdBenchmarkAccounts BenchmarkAccount[] @relation("BenchmarkAccountCreator")
  benchmarkAccountMembers BenchmarkAccountMember[]
  douyinLoginSessions DouyinLoginSession[]
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

enum OrganizationType {
  GROUP
  BRANCH
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DouyinAccountLoginStatus {
  NOT_LOGGED_IN
  PENDING
  LOGGED_IN
  EXPIRED
  FAILED
}

enum DouyinLoginSessionPurpose {
  CREATE_ACCOUNT
  RELOGIN
}

enum DouyinLoginSessionStatus {
  CREATED
  QRCODE_READY
  SCANNED
  CONFIRMED
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum BenchmarkAccountMemberSource {
  MANUAL
  COLLECTION_SYNC
}

model DouyinAccount {
  id             String            @id @default(cuid())
  profileUrl     String            @unique
  secUserId      String?           @unique
  nickname       String
  avatar         String
  bio            String?
  signature      String?
  followersCount Int               @default(0)
  followingCount Int               @default(0)
  likesCount     Int               @default(0)
  videosCount    Int               @default(0)
  douyinNumber   String?
  ipLocation     String?
  age            Int?
  province       String?
  city           String?
  verificationLabel   String?
  verificationIconUrl String?
  verificationType    Int?
  loginStatus    DouyinAccountLoginStatus @default(NOT_LOGGED_IN)
  loginStatePath String?
  loginStateUpdatedAt DateTime?
  loginStateCheckedAt DateTime?
  loginStateExpiresAt DateTime?
  loginErrorMessage String?
  favoriteCookieHeader String?
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  videos         DouyinVideo[]
  collectionVideos EmployeeCollectionVideo[]
  loginSessions  DouyinLoginSession[]
  lastSyncedAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  @@index([userId])
  @@index([organizationId])
  @@map("douyin_accounts")
}

model BenchmarkAccount {
  id                 String                  @id @default(cuid())
  profileUrl         String
  secUserId          String?
  nickname           String
  avatar             String
  bio                String?
  signature          String?
  followersCount     Int                     @default(0)
  followingCount     Int                     @default(0)
  likesCount         Int                     @default(0)
  videosCount        Int                     @default(0)
  douyinNumber       String?
  ipLocation         String?
  age                Int?
  province           String?
  city               String?
  verificationLabel  String?
  verificationIconUrl String?
  verificationType   Int?
  createdByUserId    String
  createdByUser      User                    @relation("BenchmarkAccountCreator", fields: [createdByUserId], references: [id])
  organizationId     String
  organization       Organization            @relation(fields: [organizationId], references: [id])
  members            BenchmarkAccountMember[]
  videos             BenchmarkVideo[]
  lastSyncedAt       DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?

  @@index([createdByUserId])
  @@index([organizationId])
  @@unique([organizationId, profileUrl])
  @@unique([organizationId, secUserId])
  @@map("benchmark_accounts")
}

model BenchmarkAccountMember {
  id                 String                       @id @default(cuid())
  benchmarkAccountId String
  benchmarkAccount   BenchmarkAccount             @relation(fields: [benchmarkAccountId], references: [id])
  userId             String
  user               User                         @relation(fields: [userId], references: [id])
  organizationId     String
  organization       Organization                 @relation(fields: [organizationId], references: [id])
  source             BenchmarkAccountMemberSource
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@unique([benchmarkAccountId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("benchmark_account_members")
}

model EmployeeCollectionVideo {
  id              String        @id @default(cuid())
  accountId       String
  account         DouyinAccount @relation(fields: [accountId], references: [id])
  awemeId         String
  authorSecUserId String?
  createdAt       DateTime      @default(now())

  @@unique([accountId, awemeId])
  @@index([accountId, createdAt])
  @@map("employee_collection_videos")
}

model DouyinLoginSession {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation(fields: [userId], references: [id])
  organizationId     String
  organization       Organization             @relation(fields: [organizationId], references: [id])
  accountId          String?
  account            DouyinAccount?           @relation(fields: [accountId], references: [id])
  purpose            DouyinLoginSessionPurpose
  status             DouyinLoginSessionStatus @default(CREATED)
  qrcodeDataUrl      String?
  resolvedSecUserId  String?
  errorCode          String?
  errorMessage       String?
  expiresAt          DateTime?
  startedAt          DateTime                 @default(now())
  finishedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([accountId])
  @@index([organizationId, status])
  @@map("douyin_login_sessions")
}

model DouyinVideo {
  id           String        @id @default(cuid())
  videoId      String        @unique
  accountId    String
  account      DouyinAccount @relation(fields: [accountId], references: [id])
  title        String
  coverUrl     String?
  coverSourceUrl String?
  coverStoragePath String?
  videoUrl     String?
  videoSourceUrl String?
  videoStoragePath String?
  publishedAt  DateTime?
  playCount    Int           @default(0)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  collectCount Int           @default(0)
  admireCount  Int           @default(0)
  recommendCount Int         @default(0)
  tags         String[]      @default([])
  snapshots    VideoSnapshot[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([accountId])
  @@map("douyin_videos")
}

model BenchmarkVideo {
  id               String                  @id @default(cuid())
  videoId          String
  accountId        String
  account          BenchmarkAccount        @relation(fields: [accountId], references: [id])
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id])
  title            String
  coverUrl         String?
  coverSourceUrl   String?
  coverStoragePath String?
  videoUrl         String?
  videoSourceUrl   String?
  videoStoragePath String?
  publishedAt      DateTime?
  playCount        Int                     @default(0)
  likeCount        Int                     @default(0)
  commentCount     Int                     @default(0)
  shareCount       Int                     @default(0)
  collectCount     Int                     @default(0)
  admireCount      Int                     @default(0)
  recommendCount   Int                     @default(0)
  tags             String[]                @default([])
  snapshots        BenchmarkVideoSnapshot[]
  transcription    Transcription?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  deletedAt        DateTime?

  @@index([accountId])
  @@index([organizationId])
  @@unique([accountId, videoId])
  @@map("benchmark_videos")
}

model VideoSnapshot {
  id            String      @id @default(cuid())
  videoId       String
  video         DouyinVideo @relation(fields: [videoId], references: [id])
  timestamp     DateTime    @default(now())
  playsCount    Int
  likesCount    Int
  commentsCount Int
  sharesCount   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([videoId])
  @@index([videoId, timestamp])
  @@map("video_snapshots")
}

model BenchmarkVideoSnapshot {
  id            String         @id @default(cuid())
  videoId       String
  video         BenchmarkVideo @relation(fields: [videoId], references: [id])
  timestamp     DateTime       @default(now())
  playsCount    Int
  likesCount    Int
  commentsCount Int
  sharesCount   Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([videoId])
  @@index([videoId, timestamp])
  @@map("benchmark_video_snapshots")
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transcription {
  id           String              @id @default(cuid())
  videoId      String              @unique
  video        BenchmarkVideo      @relation(fields: [videoId], references: [id])
  status       TranscriptionStatus @default(PENDING)
  aiModel      String
  originalText String?
  editedText   String?
  errorMessage String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("transcriptions")
}
