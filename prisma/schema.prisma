generator client {
  provider      = "prisma-client-js"
  // native = 当前机器（Mac/Windows 开发用）
  // debian-openssl-3.0.x = 宝塔服务器 Linux x64 Debian/Ubuntu
  // rhel-openssl-3.0.x / rhel-openssl-1.1.x = 宝塔/CentOS/Alibaba Cloud Linux 等 RHEL 系
  // linux-musl-openssl-3.0.x = Docker Alpine
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "rhel-openssl-1.1.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  status    OrganizationStatus @default(ACTIVE)
  parentId  String?
  parent    Organization?    @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[]   @relation("OrgTree")
  users     User[]
  fragments Fragment[]
  douyinAccounts DouyinAccount[]
  benchmarkAccounts BenchmarkAccount[]
  benchmarkAccountMembers BenchmarkAccountMember[]
  benchmarkVideos BenchmarkVideo[]
  aiWorkspaces AiWorkspace[]
  aiWorkspaceTranscripts AiWorkspaceTranscript[]
  aiTranscriptSegments AiTranscriptSegment[]
  aiDecompositionAnnotations AiDecompositionAnnotation[]
  aiRewriteDrafts AiRewriteDraft[]
  rewrites Rewrite[]
  douyinLoginSessions DouyinLoginSession[]
  crawlerCookies CrawlerCookie[]
  accountVideoSyncProfiles AccountVideoSyncProfile[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  account        String       @unique
  passwordHash   String
  name           String
  role           UserRole     @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdFragments Fragment[] @relation("FragmentCreator")
  douyinAccounts DouyinAccount[]
  createdBenchmarkAccounts BenchmarkAccount[] @relation("BenchmarkAccountCreator")
  benchmarkAccountMembers BenchmarkAccountMember[]
  douyinLoginSessions DouyinLoginSession[]
  aiWorkspaces AiWorkspace[]
  aiDecompositionAnnotations AiDecompositionAnnotation[]
  rewrites Rewrite[]
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

model Fragment {
  id              String       @id @default(cuid())
  content         String       @db.Text
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdByUserId String
  createdByUser   User         @relation("FragmentCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([organizationId])
  @@index([createdByUserId])
  @@map("fragments")
}

enum OrganizationType {
  GROUP
  BRANCH
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DouyinAccountLoginStatus {
  NOT_LOGGED_IN
  PENDING
  LOGGED_IN
  EXPIRED
  FAILED
}

enum DouyinLoginSessionPurpose {
  CREATE_ACCOUNT
  RELOGIN
}

enum DouyinLoginSessionStatus {
  CREATED
  QRCODE_READY
  SCANNED
  CONFIRMED
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum BenchmarkAccountMemberSource {
  MANUAL
  COLLECTION_SYNC
}

enum AccountSyncType {
  MY_ACCOUNT
  BENCHMARK_ACCOUNT
}

enum AccountVideoSyncStatus {
  ACTIVE
  COOLDOWN
  LOW_ACTIVITY
  STOPPED_BANNED
}

model DouyinAccount {
  id             String            @id @default(cuid())
  profileUrl     String            @unique
  secUserId      String?           @unique
  nickname       String
  avatar         String            @db.Text
  bio            String?           @db.Text
  signature      String?           @db.Text
  followersCount Int               @default(0)
  followingCount Int               @default(0)
  likesCount     Int               @default(0)
  videosCount    Int               @default(0)
  douyinNumber   String?
  ipLocation     String?
  age            Int?
  province       String?
  city           String?
  verificationLabel   String?
  verificationIconUrl String?       @db.Text
  verificationType    Int?
  loginStatus    DouyinAccountLoginStatus @default(NOT_LOGGED_IN)
  loginStatePath String?           @db.Text
  loginStateUpdatedAt DateTime?
  loginStateCheckedAt DateTime?
  loginStateExpiresAt DateTime?
  loginErrorMessage String?        @db.Text
  favoriteCookieHeader String?     @db.LongText
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  videos         DouyinVideo[]
  collectionVideos EmployeeCollectionVideo[]
  loginSessions  DouyinLoginSession[]
  lastSyncedAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  rewrites       Rewrite[]

  @@index([userId])
  @@index([organizationId])
  @@map("douyin_accounts")
}

model BenchmarkAccount {
  id                 String                  @id @default(cuid())
  profileUrl         String
  secUserId          String?
  nickname           String
  avatar             String                  @db.Text
  bio                String?                 @db.Text
  signature          String?                 @db.Text
  followersCount     Int                     @default(0)
  followingCount     Int                     @default(0)
  likesCount         Int                     @default(0)
  videosCount        Int                     @default(0)
  douyinNumber       String?
  ipLocation         String?
  age                Int?
  province           String?
  city               String?
  verificationLabel  String?
  verificationIconUrl String?                @db.Text
  verificationType   Int?
  createdByUserId    String
  createdByUser      User                    @relation("BenchmarkAccountCreator", fields: [createdByUserId], references: [id])
  organizationId     String
  organization       Organization            @relation(fields: [organizationId], references: [id])
  members            BenchmarkAccountMember[]
  videos             BenchmarkVideo[]
  lastSyncedAt       DateTime?
  bannedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?

  @@index([createdByUserId])
  @@index([organizationId])
  @@index([organizationId, bannedAt])
  @@unique([organizationId, profileUrl])
  @@unique([organizationId, secUserId])
  @@map("benchmark_accounts")
}

model AccountVideoSyncProfile {
  accountType             AccountSyncType
  accountId               String
  organizationId          String
  organization            Organization           @relation(fields: [organizationId], references: [id])
  status                  AccountVideoSyncStatus @default(ACTIVE)
  priority                Int                    @default(0)
  lastVideoPublishedAt    DateTime?
  lastAttemptAt           DateTime?
  lastSuccessAt           DateTime?
  lastFailureAt           DateTime?
  nextSyncAt              DateTime?
  cooldownUntil           DateTime?
  fastFollowUntil         DateTime?
  consecutiveFailureCount Int                    @default(0)
  consecutiveNoNewCount   Int                    @default(0)
  publishWindowsJson      Json                   @default("[]")
  hourlyDistributionJson  Json                   @default("[]")
  notes                   Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@id([accountType, accountId])
  @@index([organizationId, status])
  @@index([nextSyncAt, status, priority])
  @@map("account_video_sync_profiles")
}

model BenchmarkAccountMember {
  id                 String                       @id @default(cuid())
  benchmarkAccountId String
  benchmarkAccount   BenchmarkAccount             @relation(fields: [benchmarkAccountId], references: [id])
  userId             String
  user               User                         @relation(fields: [userId], references: [id])
  organizationId     String
  organization       Organization                 @relation(fields: [organizationId], references: [id])
  source             BenchmarkAccountMemberSource
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@unique([benchmarkAccountId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("benchmark_account_members")
}

model EmployeeCollectionVideo {
  id              String        @id @default(cuid())
  accountId       String
  account         DouyinAccount @relation(fields: [accountId], references: [id])
  awemeId         String
  authorSecUserId String?
  createdAt       DateTime      @default(now())

  @@unique([accountId, awemeId])
  @@index([accountId, createdAt])
  @@map("employee_collection_videos")
}

model DouyinLoginSession {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation(fields: [userId], references: [id])
  organizationId     String
  organization       Organization             @relation(fields: [organizationId], references: [id])
  accountId          String?
  account            DouyinAccount?           @relation(fields: [accountId], references: [id])
  purpose            DouyinLoginSessionPurpose
  status             DouyinLoginSessionStatus @default(CREATED)
  qrcodeDataUrl      String?          @db.LongText
  resolvedSecUserId  String?
  errorCode          String?
  errorMessage       String?          @db.Text
  expiresAt          DateTime?
  startedAt          DateTime                 @default(now())
  finishedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([accountId])
  @@index([organizationId, status])
  @@map("douyin_login_sessions")
}

model DouyinVideo {
  id           String        @id @default(cuid())
  videoId      String        @unique
  accountId    String
  account      DouyinAccount @relation(fields: [accountId], references: [id])
  title        String        @db.Text
  shareUrl     String?       @db.Text
  coverUrl     String?       @db.Text
  coverSourceUrl String?     @db.Text
  coverStoragePath String?   @db.Text
  videoUrl     String?       @db.Text
  videoSourceUrl String?     @db.Text
  videoStoragePath String?   @db.Text
  publishedAt  DateTime?
  playCount    Int           @default(0)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  collectCount Int           @default(0)
  admireCount  Int           @default(0)
  recommendCount Int         @default(0)
  // MySQL 不支持原生数组，使用 JSON 存储。要求 MySQL 8.0.13+
  tags         Json          @default("[]")
  snapshots    VideoSnapshot[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([accountId])
  @@map("douyin_videos")
}

model BenchmarkVideo {
  id               String                  @id @default(cuid())
  videoId          String
  accountId        String
  account          BenchmarkAccount        @relation(fields: [accountId], references: [id])
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id])
  title            String                  @db.Text
  shareUrl         String?                 @db.Text
  coverUrl         String?                 @db.Text
  coverSourceUrl   String?                 @db.Text
  coverStoragePath String?                 @db.Text
  videoUrl         String?                 @db.Text
  videoSourceUrl   String?                 @db.Text
  videoStoragePath String?                 @db.Text
  publishedAt      DateTime?
  playCount        Int                     @default(0)
  likeCount        Int                     @default(0)
  commentCount     Int                     @default(0)
  shareCount       Int                     @default(0)
  collectCount     Int                     @default(0)
  admireCount      Int                     @default(0)
  recommendCount   Int                     @default(0)
  // MySQL 不支持原生数组，使用 JSON 存储。要求 MySQL 8.0.13+
  tags             Json                    @default("[]")
  customTag        BenchmarkVideoTag?
  isBringOrder     Boolean                 @default(false)
  snapshots        BenchmarkVideoSnapshot[]
  transcription    Transcription?
  aiWorkspaces     AiWorkspace[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  deletedAt        DateTime?

  @@index([accountId])
  @@index([organizationId])
  @@index([organizationId, publishedAt])
  @@unique([accountId, videoId])
  @@map("benchmark_videos")
}

model VideoSnapshot {
  id            String      @id @default(cuid())
  videoId       String
  video         DouyinVideo @relation(fields: [videoId], references: [id])
  timestamp     DateTime    @default(now())
  playsCount    Int
  likesCount    Int
  commentsCount Int
  sharesCount   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([videoId])
  @@index([videoId, timestamp])
  @@map("video_snapshots")
}

model BenchmarkVideoSnapshot {
  id            String         @id @default(cuid())
  videoId       String
  video         BenchmarkVideo @relation(fields: [videoId], references: [id])
  timestamp     DateTime       @default(now())
  playsCount    Int
  likesCount    Int
  commentsCount Int
  sharesCount   Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([videoId])
  @@index([videoId, timestamp])
  @@map("benchmark_video_snapshots")
}

enum BenchmarkVideoTag {
  LIMIT_UP
  DRAGON_TIGER
  OVERNIGHT
  DARK_POOL
  THEME_REVIEW
  THREE_DRAGONS
  NOON_REVIEW
  RECAP
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiStep {
  TRANSCRIBE
  DECOMPOSE
  REWRITE
}

enum AiWorkspaceStatus {
  IDLE
  TRANSCRIBING
  TRANSCRIPT_DRAFT
  TRANSCRIPT_CONFIRMED
  DECOMPOSING
  DECOMPOSED
  REWRITING
}

enum AiVideoInputMode {
  NONE
  OSS_FILE
  GOOGLE_FILE
}

model AiModelConfig {
  id             String           @id @default(cuid())
  name           String
  baseUrl        String           @db.Text
  apiKey         String           @db.Text
  modelName      String
  videoInputMode AiVideoInputMode @default(NONE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stepBindings   AiStepBinding[]
  rewriteVersions RewriteVersion[]

  @@map("ai_model_configs")
}

model AiStepBinding {
  id            String          @id @default(cuid())
  step          AiStep          @unique
  modelConfigId String?
  modelConfig   AiModelConfig?  @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("ai_step_bindings")
}

model AiWorkspace {
  id               String            @id @default(cuid())
  videoId          String
  video            BenchmarkVideo    @relation(fields: [videoId], references: [id])
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  status           AiWorkspaceStatus @default(IDLE)
  enteredRewriteAt DateTime?
  transcript       AiWorkspaceTranscript?
  segments         AiTranscriptSegment[]
  annotations      AiDecompositionAnnotation[]
  rewriteDraft     AiRewriteDraft?
  rewrite          Rewrite?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([videoId, userId])
  @@index([organizationId])
  @@map("ai_workspaces")
}

model AiWorkspaceTranscript {
  id            String      @id @default(cuid())
  workspaceId   String      @unique
  workspace     AiWorkspace @relation(fields: [workspaceId], references: [id])
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id])
  originalText  String?     @db.LongText
  currentText   String?     @db.LongText
  isConfirmed   Boolean     @default(false)
  confirmedAt   DateTime?
  lastEditedAt  DateTime?
  aiProviderKey String?
  aiModel       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([organizationId])
  @@map("ai_workspace_transcripts")
}

model AiTranscriptSegment {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   AiWorkspace @relation(fields: [workspaceId], references: [id])
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id])
  sortOrder   Int
  text        String      @db.Text
  summary     String?     @db.Text
  purpose     String?     @db.Text
  startOffset Int
  endOffset   Int
  annotations AiDecompositionAnnotation[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([workspaceId, sortOrder])
  @@index([organizationId])
  @@map("ai_transcript_segments")
}

model AiDecompositionAnnotation {
  id             String      @id @default(cuid())
  workspaceId     String
  workspace       AiWorkspace @relation(fields: [workspaceId], references: [id])
  segmentId       String?
  segment         AiTranscriptSegment? @relation(fields: [segmentId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  startOffset     Int
  endOffset       Int
  quotedText      String      @db.Text
  function        String?     @db.Text
  argumentRole    String?     @db.Text
  technique       String?     @db.Text
  purpose         String?     @db.Text
  effectiveness   String?     @db.Text
  note            String?     @db.Text
  createdByUserId String
  createdByUser   User        @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([workspaceId])
  @@index([organizationId])
  @@index([workspaceId, startOffset, endOffset])
  @@map("ai_decomposition_annotations")
}

model AiRewriteDraft {
  id                          String      @id @default(cuid())
  workspaceId                 String      @unique
  workspace                   AiWorkspace @relation(fields: [workspaceId], references: [id])
  organizationId              String
  organization                Organization @relation(fields: [organizationId], references: [id])
  sourceTranscriptText        String?     @db.LongText
  sourceDecompositionSnapshot Json?
  currentDraft                String?     @db.LongText
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@index([organizationId])
  @@map("ai_rewrite_drafts")
}

model Transcription {
  id           String              @id @default(cuid())
  videoId      String              @unique
  video        BenchmarkVideo      @relation(fields: [videoId], references: [id])
  status       TranscriptionStatus @default(PENDING)
  aiModel      String
  originalText String?     @db.LongText
  editedText   String?     @db.LongText
  errorMessage String?     @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("transcriptions")
}

// ─── Rewrite 仿写 ────────────────────────────────────────────────────────────

enum RewriteVersionStatus {
  GENERATING
  COMPLETED
  FAILED
}

model Rewrite {
  id              String           @id @default(cuid())
  workspaceId     String           @unique
  targetAccountId String?
  organizationId  String
  userId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workspace     AiWorkspace      @relation(fields: [workspaceId], references: [id])
  targetAccount DouyinAccount?   @relation(fields: [targetAccountId], references: [id])
  organization  Organization     @relation(fields: [organizationId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  versions      RewriteVersion[]

  @@index([organizationId])
  @@index([userId])
  @@map("rewrites")
}

model RewriteVersion {
  id               String               @id @default(cuid())
  rewriteId        String
  versionNumber    Int
  generatedContent String?              @db.Text
  editedContent    String?              @db.Text
  modelConfigId    String?
  usedFragmentIds  Json                 @default("[]")
  userInputContent String?              @db.Text
  status           RewriteVersionStatus @default(GENERATING)
  errorMessage     String?              @db.Text
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  rewrite     Rewrite        @relation(fields: [rewriteId], references: [id])
  modelConfig AiModelConfig? @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)

  @@unique([rewriteId, versionNumber])
  @@index([rewriteId])
  @@map("rewrite_versions")
}

// ─── CrawlerCookie 爬虫Cookie ─────────────────────────────────────────────────

model CrawlerCookie {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  value          String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@map("crawler_cookies")
}
