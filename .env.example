# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_newline"
REDIS_URL="redis://:password@127.0.0.1:6379"

# NextAuth
# Development: leave NEXTAUTH_URL unset so Auth.js follows the current host/port.
# Production: set NEXTAUTH_URL to the public app origin, e.g. https://app.example.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-secret-must-be-32-chars"

# Crawler API
# Development: optional, omitted values will make CrawlerService return mock data.
# Production: required, e.g. https://crawler.example.com
# CRAWLER_API_URL="https://crawler.example.com"

# Seed
SEED_ADMIN_ACCOUNT="admin"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
SEED_ADMIN_NAME="超级管理员"
SEED_ORG_NAME="总部"
