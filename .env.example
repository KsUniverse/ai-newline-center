# =====================================================================
# AI Newline Center — 环境变量配置模板
# =====================================================================
#
# 【使用说明】
#   本地开发:  复制为 .env.local，填入本地值，运行 pnpm dev
#   生产服务器: 在服务器上创建 .env.production，填入生产值，运行 start.sh
#
# 【文件说明】
#   .env.example    → 此模板文件（提交 Git，不含真实值）
#   .env.local      → 本地开发专用（不提交 Git，只在本机有）
#   .env.production → 生产服务器专用（不提交 Git，只在服务器上有）
#
# =====================================================================


# ─── 数据库 ──────────────────────────────────────────────────────────
# MySQL 8.0 连接字符串
# 本地开发示例: mysql://root:password@localhost:3306/ai_newline
# 服务器示例:   mysql://ai_newline:密码@127.0.0.1:3306/ai_newline
DATABASE_URL="mysql://root:password@localhost:3306/ai_newline?charset=utf8mb4"


# ─── Redis ───────────────────────────────────────────────────────────
# 任务队列所需。不填则 AI 任务队列 / 爬虫同步队列不可用
# 本地示例: redis://localhost:6379
# 有密码示例: redis://:yourpassword@localhost:6379
REDIS_URL="redis://localhost:6379"


# ─── 认证 (NextAuth) ──────────────────────────────────────────────────
# 32位以上随机密钥，生产环境必须用强密钥
# 生成命令: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-key-change-in-production-min-32-chars!!"

# 服务完整访问地址（生产环境必填）
# 开发环境可留空（自动使用 http://localhost:3000）
# 生产示例: http://47.96.227.116:3000  或  https://yourdomain.com
NEXTAUTH_URL="http://47.96.227.116:3000"
# 自托管 / PM2 / 反向代理部署建议开启，避免 Auth.js 报 UntrustedHost
AUTH_TRUST_HOST="true"


# ─── 爬虫 API ─────────────────────────────────────────────────────────
# 抖音数据爬虫服务地址（生产环境必填）
CRAWLER_API_URL="http://localhost:8011"


# ─── AI 服务 ──────────────────────────────────────────────────────────
# 火山引擎 ARK（视频转写 + AI 拆解 + 仿写，推荐）
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_TRANSCRIBE_MODEL=""
ARK_DECOMPOSE_MODEL=""
ARK_REWRITE_MODEL=""

# 通用转写覆盖（TRANSCRIBE_* 优先级高于 ARK_* 中的转写配置）
TRANSCRIBE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3/chat/completions"
TRANSCRIBE_API_KEY=""
TRANSCRIBE_MODEL_NAME=""

# Deepgram（语音识别，可选）
DEEPGRAM_API_KEY=""

# OpenAI（可选）
OPENAI_API_KEY=""

# Google Gemini（可选）
GOOGLE_API_KEY=""


# ─── 定时任务（cron 表达式，留空使用系统默认值）──────────────────────
# ACCOUNT_SYNC_CRON="0 * * * *"
# VIDEO_SYNC_CRON="0 2 * * *"
# VIDEO_SNAPSHOT_CRON="0 4 * * *"
# COLLECTION_SYNC_CRON="30 3 * * *"


# ─── 抖音扫码登录（可选高级配置）────────────────────────────────────
# DOUYIN_LOGIN_STATE_DIR=""
# DOUYIN_LOGIN_PAGE_URL="https://www.douyin.com/"
# DOUYIN_LOGIN_OPEN_DEVTOOLS="false"
# DOUYIN_LOGIN_TIMEOUT_MS="180000"


# ─── 阿里云 OSS（可选，推荐生产环境使用）────────────────────────────
# 配置后，封面图片和视频将存储到 OSS，否则存储到服务器本地磁盘
#
# OSS_ACCESS_BUCKET_ENDPOINT 格式: https://bucket名称.oss-地域.aliyuncs.com
# 示例: https://my-ai-center.oss-cn-hangzhou.aliyuncs.com
#
# 注意: OSS Bucket 需设置为「公共读」权限，否则图片/视频无法访问
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_ACCESS_BUCKET_ENDPOINT=""


# ─── 数据库初始化 Seed（仅运行 pnpm db:seed 时使用）──────────────────
SEED_ADMIN_ACCOUNT="admin"
SEED_ADMIN_PASSWORD="Admin123456"
SEED_ADMIN_NAME="超级管理员"
SEED_ORG_NAME="总部"
