# Database — MySQL 连接（宝塔 MySQL 8.0）
DATABASE_URL="mysql://ai_newline:your-db-password@127.0.0.1:3306/ai_newline?charset=utf8mb4"

# Redis — 可选，未配置时任务队列功能不可用
REDIS_URL="redis://:123@localhost:6379"

# NextAuth
# 开发环境不要固定 NEXTAUTH_URL，避免切换端口后跳到旧端口。
# 开发环境密钥（生产环境用 openssl rand -base64 32 生成新密钥）
NEXTAUTH_SECRET="dev-secret-key-for-local-only-do-not-use-in-prod"
NEXTAUTH_URL="http://47.96.227.116:3000"
AUTH_TRUST_HOST="true"
CRAWLER_API_URL="http://localhost:8011"

# Seed 初始账号（运行 pnpm db:seed 时使用）
SEED_ADMIN_ACCOUNT="admin"
SEED_ADMIN_PASSWORD="Admin123456"
SEED_ADMIN_NAME="超级管理员"
SEED_ORG_NAME="总部"

TRANSCRIBE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3/chat/completions"
TRANSCRIBE_API_KEY="2914b0c2-90f0-42a5-9018-6bd2054072b8"
TRANSCRIBE_MODEL_NAME="doubao-seed-2-0-lite-260215"


# ---- Docker 专用（使用 docker-compose.yml 时填写）----
# 如需 Docker 方式部署，参考 docker-compose.yml 中的 mysql 镜像配置
# MYSQL_DATABASE=ai_newline
# MYSQL_ROOT_PASSWORD=your-db-password
# REDIS_PASSWORD=your-redis-password
# APP_IMAGE=ai-newline-center:latest
# APP_PORT=3000
