# ============================================================
# 生产环境配置模板 — .env.production.example
# 
# 使用方式:
#   cp .env.production.example .env
# 然后按注释填写每个值
# ============================================================

# ---- 数据库 (MySQL 8.0+，宝塔已安装) ----
# 格式: mysql://用户名:密码@主机:端口/数据库名
# ?charset=utf8mb4 确保中文等Unicode字符正常存储
DATABASE_URL="mysql://root:your-mysql-password@127.0.0.1:3306/ai_newline?charset=utf8mb4"

# ---- Redis (宝塔已安装的 Redis) ----
# 格式: redis://:密码@主机:端口
REDIS_URL="redis://:your-redis-password@127.0.0.1:6379"

# ---- NextAuth ----
# NEXTAUTH_URL: 应用的公网访问地址（含端口，或反代后的域名）
NEXTAUTH_URL="http://your-server-ip:3000"
# NEXTAUTH_SECRET: 至少32位随机字符串
# 生成命令: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-secret-minimum-32-chars"

# ---- 应用端口 ----
PORT=3000

# ---- 爬虫 API（可选，不填则爬虫功能不可用）----
CRAWLER_API_URL="http://127.0.0.1:8011"

# ---- AI API Keys（可选，不填则对应 AI 功能不可用）----
DEEPGRAM_API_KEY=""
GOOGLE_API_KEY=""
DASHSCOPE_API_KEY=""

# ---- 种子数据（仅首次初始化时使用）----
SEED_ADMIN_ACCOUNT="admin"
SEED_ADMIN_PASSWORD="replace-with-strong-admin-password"
SEED_ADMIN_NAME="超级管理员"
SEED_ORG_NAME="总部"

# ---- Docker 专用（使用 docker-compose.yml 时填写）----
# 如需 Docker 方式部署，需更换 docker-compose.yml 中的 postgres → mysql 镜像
# MYSQL_DATABASE=ai_newline
# MYSQL_ROOT_PASSWORD=your-db-password
# REDIS_PASSWORD=your-redis-password
# APP_IMAGE=ai-newline-center:latest
# APP_PORT=3000
